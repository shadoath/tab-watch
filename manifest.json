{
  "manifest_version": 3,
  "name": "TabWatch",
  "version": "1.0.0",
  "description": "See how long every tab has been open. Search, sort by duration or title, and jump to any tab in one click.",
  "homepage_url": "https://github.com/shadoath/tab-watch",
  "permissions": ["tabs", "storage", "windows"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabWatch",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
